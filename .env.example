# Canonical public site origin. Do not include a trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Keep the CSS hero enabled unless the optional WebGL experience is explicitly tested.
NEXT_PUBLIC_ENABLE_WEBGL_HERO=false

# Sanity public configuration. The application must use local fallback content when absent.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=

# Server-only Sanity secrets. Never expose these with a NEXT_PUBLIC_ prefix.
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

# Google Places API (New) reviews. All values are server-only; never add NEXT_PUBLIC_ prefixes.
# Keep disabled until the owner-verified Place ID, Maps URL, billing, quota and legal pages are ready.
GOOGLE_REVIEWS_ENABLED=false
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Optional owner-verified Google Maps listing used only as a link when live reviews are unavailable.
GOOGLE_MAPS_PLACE_URL=
