# Canonical public site origin. Do not include a trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Keep the CSS hero enabled unless the optional WebGL experience is explicitly tested.
NEXT_PUBLIC_ENABLE_WEBGL_HERO=false

# Sanity public configuration. The application must use local fallback content when absent.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=

# Server-only Sanity secrets. Never expose these with a NEXT_PUBLIC_ prefix.
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

